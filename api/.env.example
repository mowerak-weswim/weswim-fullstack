APP_ENV=development
PORT=8000
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# HS256 legacy only; local Supabase may sign JWTs with ES256 (JWKS auto-fetched)
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# Staging/prod: comma-separated frontend URLs
# CORS_ORIGINS=https://weswim-frontend.vercel.app
# Vercel Preview (credentials=true → regex required)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
